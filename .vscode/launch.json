{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Run subeclipse (Debug)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build-debug/subeclipse",
            "args": [],
            "stopAtEntry": false,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "miDebuggerPath": "/usr/bin/gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "description": "彻底关闭烦人的 debuginfod 联网下载",
                    "text": "set debuginfod enabled off",
                    "ignoreFailures": true
                }
            ],
            "preLaunchTask": "Build Debug"
        },
