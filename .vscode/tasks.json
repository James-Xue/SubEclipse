{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "Configure Release",
            "type": "shell",
            "command": "cmake -S . -B build -DCMAKE_BUILD_TYPE=Release",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "problemMatcher": []
        },
        {
            "label": "Build Release",
            "type": "shell",
            "command": "cmake --build build -j",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Configure Release"
            ],
            "dependsOrder": "sequence",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "problemMatcher": []
        },
        {
            "label": "Rebuild Release",
            "type": "shell",
            "command": "cmake --build build --target clean && cmake --build build -j",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "dependsOn": [
                "Configure Release"
            ],
            "dependsOrder": "sequence",
            "problemMatcher": []
        }
    ]
}